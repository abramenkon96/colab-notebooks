      "source": [
        "#@title 🚀 Универсальный транскрибатор + AI (Gemini API)\n",
        "import torch\n",
        "import sys\n",
        "import re\n",
        "import json\n",
        "import os\n",
        "\n",
        "\n",
        "# --- 0. Проверка оборудования ---\n",
        "def check_gpu():\n",
        "    print(\"🔍 Проверяю настройки оборудования...\")\n",
        "    if not torch.cuda.is_available():\n",
        "        print(\"\\n❌ ОШИБКА: GPU не обнаружен!\")\n",
        "        return False\n",
        "    print(f\"✅ Обнаружен: {torch.cuda.get_device_name(0)}\")\n",
        "    return True\n",
        "\n",
        "if not check_gpu():\n",
        "    sys.exit(\"⛔ Остановка: переключитесь на T4 GPU!\")\n",
        "\n",
        "# --- 1. Установка и импорты ---\n",
        "print(\"\\n⏳ Устанавливаю зависимости...\")\n",
        "!apt-get install -y ffmpeg\n",
        "!pip install -q faster-whisper google-generativeai tenacity pydub\n",
        "from google.colab import drive\n",
        "from faster_whisper import WhisperModel\n",
        "import google.generativeai as genai\n",
        "import time\n",
        "from tenacity import retry, stop_after_attempt, wait_exponential\n",
        "from pydub import AudioSegment\n",
        "import math\n",
        "\n",
        "# --- Очистка мусора ---\n",
        "import glob\n",
        "for f in glob.glob(\"/content/*.mp3\"): # Удаляем временные куски аудио\n",
        "    try: os.remove(f)\n",
        "    except: pass\n",
        "\n",
        "#@markdown ### 📁 1. Пути и файлы\n",
        "folder_path = \"/content/drive/MyDrive/Лекции по общей психологии\" #@param {type:\"string\"}\n",
        "\n",
        "#@markdown ---\n",
        "#@markdown ### 🎙️ 2. Настройки транскрипции (Whisper)\n",
        "model_size = \"large-v3-turbo\" #@param [\"tiny\", \"base\", \"small\", \"medium\", \"large-v3\", \"large-v3-turbo\"]\n",
        "language = \"auto\" #@param [\"auto\", \"ru\", \"en\", \"uk\", \"de\", \"fr\", \"es\"] {allow-input: true}\n",
        "task = \"transcribe\" #@param [\"transcribe\", \"translate\"]\n",
        "save_format = \"srt\" #@param [\"txt\", \"srt\", \"json\"]\n",
        "\n",
        "#@markdown ---\n",
        "#@markdown ### 🤖 3. Настройки Gemini API\n",
        "#@markdown **ИНСТРУКЦИЯ:** Если ключ в \"Secrets\" (имя `GEMINI_API_KEY`), оставьте поле ПУСТЫМ. Вставлять БЕЗ КАВЫЧЕК.\n",
        "gemini_api_key = \"\" #@param {type:\"string\"}\n",
        "gemini_model_name = \"auto\" #@param {type:\"string\"}\n",
        "\n",
        "# Попытка достать ключ из секретов Colab\n",
        "if not gemini_api_key:\n",
        "    try:\n",
        "        from google.colab import userdata\n",
        "        gemini_api_key = userdata.get('GEMINI_API_KEY')\n",
        "        if gemini_api_key: print(\"✅ Ключ взят из Secrets.\")\n",
        "    except: pass\n",
        "\n",
        "if gemini_api_key:\n",
        "    gemini_api_key = gemini_api_key.strip(\"'\\\" \")\n",
        "\n",
        "#@markdown **Обработка текста (LLM):**\n",
        "llm_processing = \"Точная транскрипция (пунктуация, абзацы)\" #@param [\"Без обработки\", \"Точная транскрипция (пунктуация, абзацы)\", \"Очистка от мусора и заголовки\", \"Свой промпт\"]\n",
        "custom_prompt = \"\" #@param {type:\"string\"}\n",
        "create_summary = True #@param {type:\"boolean\"}\n",
        "\n",
        "# --- 2. Подключение Google Диска ---\n",
        "drive.mount('/content/drive', force_remount=True)\n",
        "\n",
        "# --- 3. Настройка Gemini API ---\n",
        "best_model_id = None\n",
        "if gemini_api_key:\n",
        "    genai.configure(api_key=gemini_api_key)\n",
        "    try:\n",
        "        models = [m for m in genai.list_models() if 'generateContent' in m.supported_generation_methods]\n",
        "        def sort_m(m):\n",
        "            n = m.name\n",
        "            match = re.search(r'gemini-(\\d+)(?:\\.(\\d+))?', n)\n",
        "            if not match: return (0,0,0,0)\n",
        "            maj, min = int(match.group(1)), (int(match.group(2)) if match.group(2) else 0)\n",
        "            pre = 1 if 'preview' in n.lower() or 'exp' in n.lower() else 0\n",
        "            typ = 3 if 'flash-lite' in n.lower() else (2 if 'flash' in n.lower() else 1)\n",
        "            return (maj, min, pre, typ)\n",
        "        sorted_m = sorted(models, key=sort_m, reverse=True)\n",
        "        best_model_id = sorted_m[0].name if gemini_model_name == \"auto\" else gemini_model_name\n",
        "        print(f\"🤖 Модель Gemini: {best_model_id}\")\n",
        "    except Exception as e: print(f\"❌ Ошибка API: {e}\")\n",
        "\n",
        "# --- 4. Функции ---\n",
        "def clean_srt(text):\n",
        "    \"\"\"Очищает SRT, сохраняя таймкоды (формат [ЧЧ:ММ:СС]) примерно каждые 5 минут (300 сек).\"\"\"\n",
        "    lines = text.split('\\n')\n",
        "    clean =[]\n",
        "    last_seconds = -999\n",
        "    \n",
        "    for line in lines:\n",
        "        line = line.strip()\n",
        "        if not line or re.match(r'^\\d+$', line): \n",
        "            continue\n",
        "            \n",
        "        if '-->' in line:\n",
        "            time_str = line.split('-->')[0].split(',')[0].strip()\n",
        "            h, m, s = map(int, time_str.split(':'))\n",
        "            current_seconds = h * 3600 + m * 60 + s\n",
        "            \n",
        "            # Ставим таймкод раз в 5 минут (300 секунд)\n",
        "            if current_seconds - last_seconds >= 300:\n",
        "                clean.append(f\"\\n[{time_str}]\")\n",
        "                last_seconds = current_seconds\n",
        "        else:\n",
        "            clean.append(line)\n",
        "            \n",
        "    return \" \".join(clean).replace(\" \\n[\", \"\\n[\")\n",
        "\n",
        "def save_transcription(output_base_path, segments_list, fmt):\n",
        "    output_path = f\"{output_base_path}.{fmt}\"\n",
        "    if fmt == \"txt\":\n",
        "        with open(output_path, \"w\", encoding=\"utf-8\") as f:\n",
        "            for s in segments_list: f.write(s['text'] + \"\\n\")\n",
        "    elif fmt == \"srt\":\n",
        "        with open(output_path, \"w\", encoding=\"utf-8\") as f:\n",
        "            for i, s in enumerate(segments_list, 1):\n",
        "                st, en = s[\"start\"], s[\"end\"]\n",
        "                t_st = f\"{int(st//3600):02}:{int((st%3600)//60):02}:{int(st%60):02},{int((st%1)*1000):03}\"\n",
        "                t_en = f\"{int(en//3600):02}:{int((en%3600)//60):02}:{int(en%60):02},{int((en%1)*1000):03}\"\n",
        "                f.write(f\"{i}\\n{t_st} --> {t_en}\\n{s['text']}\\n\\n\")\n",
        "    elif fmt == \"json\":\n",
        "        with open(output_path, \"w\", encoding=\"utf-8\") as f:\n",
        "            json.dump(segments_list, f, ensure_ascii=False, indent=2)\n",
        "\n",
        "    text_for_ai = \"\"\n",
        "    last_time = -999\n",
        "    for s in segments_list:\n",
        "        if s['start'] - last_time > 300:\n",
        "            h, m, sec = int(s['start']//3600), int((s['start']%3600)//60), int(s['start']%60)\n",
        "            text_for_ai += f\"\\n[{h:02}:{m:02}:{sec:02}] \"\n",
        "            last_time = s['start']\n",
        "        text_for_ai += s['text'] + \" \"\n",
        "    return text_for_ai\n",
        "\n",
        "def chunk_text_by_length(text, max_chars=28000):\n",
        "    chunks, current = [], \"\"\n",
        "    lines = text.split('\\n')\n",
        "    for line in lines:\n",
        "        if len(current) + len(line) < max_chars:\n",
        "            current += line + \"\\n\"\n",
        "        else:\n",
        "            if current: chunks.append(current.strip())\n",
        "            current = line + \"\\n\"\n",
        "    if current: chunks.append(current.strip())\n",
        "    return chunks\n",
        "\n",
        "@retry(stop=stop_after_attempt(5), wait=wait_exponential(multiplier=1, min=2, max=10))\n",
        "def call_gemini(p, data, model_id, is_cleaning=False):\n",
        "    if not model_id: return None\n",
        "    model = genai.GenerativeModel(model_id)\n",
        "    if is_cleaning:\n",
        "        chunks = chunk_text_by_length(data)\n",
        "        results = []\n",
        "        for idx, c in enumerate(chunks):\n",
        "            print(f\"      - Обработка части {idx+1}/{len(chunks)}...\")\n",
        "            chunk_instruction = f\"Это ЧАСТЬ №{idx+1} из {len(chunks)}. Продолжай обработку. НЕ добавляй вступлений или заголовков. Просто выдай очищенный текст: {p}\"\n",
        "            res = model.generate_content(f\"{chunk_instruction}\\n\\nТЕКСТ:\\n{c}\")\n",
        "            results.append(res.text)\n",
        "            time.sleep(2)\n",
        "        return \"\\n\\n\".join(results)\n",
        "    else:\n",
        "        res = model.generate_content(f\"{p}\\n\\nТЕКСТ:\\n{data}\")\n",
        "        return res.text\n",
        "\n",
        "# --- 5. Загрузка Whisper ---\n",
        "print(f\"\\n🧠 Загружаю Whisper {model_size}...\")\n",
        "model_w = WhisperModel(model_size, device=\"cuda\", compute_type=\"float16\")\n",
        "\n",
        "# --- 6. Основной цикл ---\n",
        "audio_ext = ('.mp3', '.wav', '.m4a', '.mp4', '.webm', '.ogg', '.flac')\n",
        "files = sorted([f for f in os.listdir(folder_path) if f.lower().endswith(audio_ext)])\n",
        "\n",
        "for i, filename in enumerate(files, 1):\n",
        "    base_name = os.path.splitext(filename)[0]\n",
        "    out_base = os.path.join(folder_path, f\"{base_name}_Transcript\")\n",
        "    print(f\"\\n[{i}/{len(files)}] 🎙️ {filename}\")\n",
        "\n",
        "    if os.path.exists(f\"{out_base}.{save_format}\"):\n",
        "        print(f\"   ⏭️ {save_format.upper()} уже есть. Подготовка для AI...\")\n",
        "        with open(f\"{out_base}.{save_format}\", \"r\", encoding=\"utf-8\") as f: content = f.read()\n",
        "        full_text_ai = clean_srt(content) if save_format == \"srt\" else content\n",
        "    else:\n",
        "        print(\"   🎙️ Нарезка аудио по 30 минут и транскрипция...\")\n",
        "        full_segments = []\n",
        "        audio = AudioSegment.from_file(os.path.join(folder_path, filename))\n",
        "        chunk_length_ms = 30 * 60 * 1000  # 30 минут\n",
        "        \n",
        "        for j in range(0, len(audio), chunk_length_ms):\n",
        "            chunk = audio[j:j + chunk_length_ms]\n",
        "            chunk_path = f\"temp_chunk_{j}.mp3\"\n",
        "            chunk.export(chunk_path, format=\"mp3\")\n",
        "            \n",
        "            # Транскрибируем кусок\n",
        "            segs, _ = model_w.transcribe(chunk_path, language=None if language==\"auto\" else language,\n",
        "                                         task=task, beam_size=1, vad_filter=True,\n",
        "                                         vad_parameters=dict(min_silence_duration_ms=2000),\n",
        "                                         condition_on_previous_text=False)\n",
        "            \n",
        "            # Смещаем время: прибавляем время начала этого куска (j в миллисекундах)\n",
        "            offset = j / 1000.0\n",
        "            for s in segs:\n",
        "                full_segments.append({'start': s.start + offset, 'end': s.end + offset, 'text': s.text.strip()})\n",
        "            \n",
        "            os.remove(chunk_path)\n",
        "            print(f\"      - Часть {j//chunk_length_ms + 1} готова\")\n",
        "\n",
        "        # Сохраняем и получаем текст для AI\n",
        "        full_text_ai = save_transcription(out_base, full_segments, save_format)\n",
        "        print(\"   ✅ Whisper готов!\")\n",
        "\n",
        "    # 2. Исправление стиля (LLM)\n",
        "    out_llm = f\"{out_base}_LLM_Cleaned.txt\"\n",
        "    out_sum = f\"{out_base}_Summary.md\"\n",
        "    cleaned = \"\"\n",
        "    \n",
        "    if best_model_id and llm_processing != \"Без обработки\":\n",
        "        if os.path.exists(out_llm):\n",
        "            print(\"   ⏭️ Очищенный текст уже есть. Читаем для конспекта...\")\n",
        "            with open(out_llm, \"r\", encoding=\"utf-8\") as f: cleaned = f.read()\n",
        "        else:\n",
        "            print(\"   🤖 Gemini: Исправление стиля...\")\n",
        "            if llm_processing == \"Точная транскрипция (пунктуация, абзацы)\":\n",
        "                p = \"Исправь пунктуацию и разбей на абзацы. Сохрани все слова-паразиты и смысл. Метки времени[ЧЧ:ММ:СС] ставь ТОЛЬКО в начале абзацев.\"\n",
        "            elif llm_processing == \"Очистка от мусора и заголовки\":\n",
        "                p = \"Удали слова-паразиты. Расставь заголовки. Исправь пунктуацию. Метки времени [ЧЧ:ММ:СС] ставь ТОЛЬКО в заголовках и начале абзацев.\"\n",
        "            else: p = custom_prompt\n",
        "            \n",
        "            cleaned = call_gemini(p, full_text_ai, best_model_id, is_cleaning=True)\n",
        "            if cleaned:\n",
        "                with open(out_llm, \"w\", encoding=\"utf-8\") as f: f.write(cleaned)\n",
        "                print(\"   ✅ Исправленный текст сохранен!\")\n",
        "\n",
        "        # 3. Саммари / Конспект (LLM)\n",
        "        if create_summary and cleaned and not os.path.exists(out_sum):\n",
        "            print(\"   📝 Gemini: Создаю академический конспект...\")\n",
        "            sum_prompt = \"\"\"\n",
        "Ты — профессиональный академический ассистент и эксперт по психологии. Твоя задача — составить максимально подробный, структурированный и глубокий конспект лекции на основе предоставленного текста.\n",
        "\n",
        "СТРУКТУРА КОНСПЕКТА:\n",
        "1. ЗАГОЛОВОК: Придумай точный заголовок, отражающий тему лекции.\n",
        "2. КРАТКАЯ СУТЬ (TL;DR): 3-5 предложений, отражающих главную научную идею и цель лекции.\n",
        "3. КЛЮЧЕВЫЕ ТЕРМИНЫ: Глоссарий понятий, упомянутых в лекции, с краткими определениями в контексте данного курса.\n",
        "4. ОСНОВНОЕ СОДЕРЖАНИЕ: Детальное изложение, разбитое на логические блоки с использованием заголовков (H2, H3). Обязательно сохраняй таймкоды [ЧЧ:ММ:СС] в начале каждого блока или подраздела.\n",
        "5. ВЫВОДЫ: Итоговые тезисы лектора.\n",
        "\n",
        "ТРЕБОВАНИЯ К КАЧЕСТВУ:\n",
        "- Стиль: Академический, сухой, емкий, профессиональный.\n",
        "- Форматирование: Markdown (жирный шрифт для терминов, списки, заголовки).\n",
        "- Детализация: Подробно описывай аргументы, методологию и примеры/кейсы. Если лектор приводит пример, оформляй его как \"Пример: [Описание]\".\n",
        "- Очистка: Удали слова-паразиты, повторы и разговорные обороты.\n",
        "- Ограничения: НЕ добавляй вступлений (\"Конечно...\", \"Вот ваш конспект...\") и заключений. Выдавай сразу готовый конспект. \n",
        "- Навигация: Таймкоды[ЧЧ:ММ:СС] должны быть сохранены для навигации по аудио.\n",
        "\n",
        "ТЕКСТ ЛЕКЦИИ ДЛЯ ОБРАБОТКИ:\n",
        "\"\"\"\n",
        "            summary = call_gemini(sum_prompt, cleaned, best_model_id, is_cleaning=False)\n",
        "            if summary:\n",
        "                with open(out_sum, \"w\", encoding=\"utf-8\") as f: f.write(summary)\n",
        "                print(\"   ✅ Конспект успешно сохранен!\")\n",
        "            else:\n",
        "                print(\"   ❌ Ошибка при создании конспекта.\")\n",
        ""
      ]
    }
  ],\n",
